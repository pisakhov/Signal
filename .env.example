ADMIN_USERNAME=admin
ADMIN_PASSWORD=
DUCKDB_PATH=./data/metadata.duckdb
PROJECTS_ROOT=./projects
TEMPLATE_DASH=./templates/dash_app.py
API_PORT=8000
WEB_PORT=3000
SESSION_SECRET=
DASH_PORT_RANGE_START=8100
CORS_ORIGINS=http://localhost:3000
# Base URL for Dash apps (useful for remote deployments)
# For local development, leave empty to use http://localhost:{port}
# For production, set to the public base URL e.g., https://your-domain.com
DASH_BASE_URL=

# IMPORTANT: Generate SESSION_SECRET with: openssl rand -hex 32
# The app will refuse to start with an empty or insecure SESSION_SECRET value.
